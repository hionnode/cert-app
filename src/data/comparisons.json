    "id": "caching-comparison",
    "title": "Caching Comparison",
    "domain": 4,
    "description": "Critical exam distinction -- know all three caching layers and when to use each.",
    "columns": ["Method", "How It Works", "When to Use", "Cost Impact"],
    "rows": [
      {
        "Method": "Bedrock Prompt Caching",
        "How It Works": "Caches system prompt at Bedrock API level. 5-min TTL (1.25x write, 0.1x read) or 1-hour TTL (2.0x write, 0.1x read). Min 1024 tokens.",
        "When to Use": "Same long system prompt across many requests",
        "Cost Impact": "Up to 90% reduction on cached tokens"
      },
      {
        "Method": "Semantic Caching (ElastiCache/DynamoDB)",
        "How It Works": "App-level: embed incoming query, compare against cached query embeddings via cosine similarity",
        "When to Use": "Repeated similar user queries",
        "Cost Impact": "Eliminates FM call entirely (86% cost reduction with ElastiCache)"
      },
      {
        "Method": "Exact-match Caching (ElastiCache)",
        "How It Works": "App-level: hash identical queries, return cached response",
        "When to Use": "Identical queries",
        "Cost Impact": "Eliminates FM call entirely"
      },
      {
        "Method": "Intelligent Prompt Routing",
        "How It Works": "Auto-analyzes each prompt and routes to most appropriate FM based on complexity",
        "When to Use": "Mixed-complexity workloads",
        "Cost Impact": "Automated model cascading without manual routing logic"
      }
    ]
