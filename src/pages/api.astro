			<!-- ConverseStream -->
			<div class="card mb-6" id="conversestream">
				<div class="p-6 border-b border-surface-3">
					<h3 class="heading-3 mb-2">ConverseStream</h3>
					<p class="body-text">Streaming variant of Converse. Returns tokens incrementally for real-time UIs. Same unified format, same tool use support.</p>
				</div>
				<div class="p-6">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
						<div>
							<h4 class="caption font-semibold uppercase tracking-wide mb-3">When to use</h4>
							<ul class="space-y-2">
								<li class="flex items-start gap-2 body-text"><span class="text-accent-aqua">-</span>Chat UIs needing real-time token display</li>
								<li class="flex items-start gap-2 body-text"><span class="text-accent-aqua">-</span>Reducing time-to-first-token</li>
								<li class="flex items-start gap-2 body-text"><span class="text-accent-aqua">-</span>WebSocket or SSE endpoints</li>
							</ul>
						</div>
						<div>
							<h4 class="caption font-semibold uppercase tracking-wide mb-3">Exam trigger</h4>
							<p class="body-text text-accent-yellow">"reduce perceived latency" or "real-time token display" = ConverseStream</p>
						</div>
					</div>

					<h4 class="caption font-semibold uppercase tracking-wide mb-3">Stream event handling</h4>
					<div class="bg-surface-0 border border-surface-3 rounded-card p-4 overflow-x-auto">
						<pre class="text-sm text-ink-secondary font-mono leading-relaxed" set:text={codeConverseStream} />
					</div>

					<div class="mt-4 flex flex-wrap gap-2">
						<a href="https://aws.amazon.com/blogs/machine-learning/build-a-generative-ai-powered-solution-on-amazon-bedrock-to-summarize-call-transcripts/" target="_blank" rel="noopener" class="badge border border-accent-blue text-accent-blue hover:bg-accent-blue/10">Blog: Real-time GenAI apps</a>
						<span class="badge-muted">Service: bedrock-runtime</span>
						<span class="badge-muted">Streaming</span>
					</div>
				</div>
