			<!-- Converse -->
			<div class="card mb-6" id="converse">
				<div class="p-6 border-b border-surface-3">
					<div class="flex items-center gap-3 mb-2">
						<h3 class="heading-3">Converse</h3>
						<span class="badge border border-accent-aqua text-accent-aqua">Recommended</span>
					</div>
					<p class="body-text">Unified, model-agnostic API for multi-turn conversations. Works identically across Claude, Nova, Llama, Mistral, and all Bedrock models without code changes.</p>
				</div>
				<div class="p-6">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div>
							<h4 class="caption font-semibold uppercase tracking-wide mb-3">When to use</h4>
							<ul class="space-y-2">
								<li class="flex items-start gap-2 body-text"><span class="text-accent-aqua">-</span>Multi-turn chatbots and assistants</li>
								<li class="flex items-start gap-2 body-text"><span class="text-accent-aqua">-</span>Function calling / tool use</li>
								<li class="flex items-start gap-2 body-text"><span class="text-accent-aqua">-</span>Model-agnostic code (switch models without changes)</li>
								<li class="flex items-start gap-2 body-text"><span class="text-accent-aqua">-</span>Vision / multimodal inputs (images + text)</li>
								<li class="flex items-start gap-2 body-text"><span class="text-accent-aqua">-</span>Guardrails integration</li>
							</ul>
						</div>
