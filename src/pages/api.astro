---
import Layout from "../layouts/Layout.astro";

// ── Runtime API examples ──────────────────────────────────────
const codeConverse = `import boto3, json

bedrock = boto3.client("bedrock-runtime", region_name="us-east-1")

response = bedrock.converse(
    modelId="us.anthropic.claude-sonnet-4-20250514",
    messages=[
        {"role": "user", "content": [{"text": "Explain RAG in 3 bullets"}]}
    ],
    system=[{"text": "You are an AWS solutions architect."}],
    inferenceConfig={"maxTokens": 512, "temperature": 0.7}
)
text = response["output"]["message"]["content"][0]["text"]
usage = response["usage"]  # inputTokens, outputTokens, totalTokens
print(text)`;

const codeConverseToolUse = `# Define tools the model can call
tool_config = {"tools": [{
    "toolSpec": {
        "name": "get_order_status",
        "description": "Look up order status by order ID",
        "inputSchema": {"json": {
            "type": "object",
            "properties": {
                "order_id": {"type": "string", "description": "The order ID"}
            },
            "required": ["order_id"]
        }}
    }
}]}

response = bedrock.converse(
    modelId="us.anthropic.claude-sonnet-4-20250514",
    messages=[{"role": "user", "content": [{"text": "Where is order #12345?"}]}],
    toolConfig=tool_config
)

# Model returns tool_use block — execute it, then send tool_result back
stop = response["stopReason"]  # "tool_use"
tool_block = response["output"]["message"]["content"][1]  # toolUse block
tool_id = tool_block["toolUse"]["toolUseId"]
tool_input = tool_block["toolUse"]["input"]  # {"order_id": "12345"}

# Execute your function, then return result
result = lookup_order(tool_input["order_id"])
messages.append(response["output"]["message"])
messages.append({"role": "user", "content": [{
    "toolResult": {"toolUseId": tool_id, "content": [{"text": json.dumps(result)}]}
}]})
final = bedrock.converse(modelId="...", messages=messages, toolConfig=tool_config)`;

const codeConverseVision = `# Send image + text (multimodal)
import base64

with open("architecture.png", "rb") as f:
    image_bytes = f.read()

response = bedrock.converse(
    modelId="us.anthropic.claude-sonnet-4-20250514",
    messages=[{"role": "user", "content": [
        {"image": {"format": "png", "source": {"bytes": image_bytes}}},
        {"text": "What AWS services are shown in this architecture diagram?"}
    ]}]
)`;

const codeConverseGuardrail = `# Attach guardrails to any Converse call
response = bedrock.converse(
    modelId="us.anthropic.claude-sonnet-4-20250514",
    messages=[{"role": "user", "content": [{"text": user_input}]}],
    guardrailConfig={
        "guardrailIdentifier": "my-guardrail-id",
        "guardrailVersion": "1",
        "trace": "enabled"  # see which filters triggered
    }
)
# If guardrail triggers: stopReason = "guardrail_intervened"`;

const codeConverseStream = `response = bedrock.converse_stream(
    modelId="us.anthropic.claude-sonnet-4-20250514",
    messages=[{"role": "user", "content": [{"text": "Write a poem about RAG"}]}]
)

# Event types in the stream:
for event in response["stream"]:
    if "contentBlockStart" in event:
        pass  # New content block beginning
    elif "contentBlockDelta" in event:
        # Incremental text — print as it arrives
        print(event["contentBlockDelta"]["delta"]["text"], end="")
    elif "contentBlockStop" in event:
        pass  # Block complete
    elif "messageStop" in event:
        stop_reason = event["messageStop"]["stopReason"]
    elif "metadata" in event:
        usage = event["metadata"]["usage"]  # final token counts`;

const codeInvokeModel = `# Model-specific format — each model family has its own schema
import json

# Claude (Anthropic format)
response = bedrock.invoke_model(
    modelId="anthropic.claude-3-sonnet-20240229-v1:0",
    body=json.dumps({
        "anthropic_version": "bedrock-2023-05-31",
        "messages": [{"role": "user", "content": "Hello"}],
        "max_tokens": 256
    })
)
result = json.loads(response["body"].read())

# Amazon Nova (different format)
response = bedrock.invoke_model(
    modelId="amazon.nova-pro-v1:0",
    body=json.dumps({
        "messages": [{"role": "user", "content": [{"text": "Hello"}]}],
        "inferenceConfig": {"maxTokens": 256}
    })
)`;

const codeEmbeddings = `# Titan Embeddings v2 — for building vector search indexes
response = bedrock.invoke_model(
    modelId="amazon.titan-embed-text-v2:0",
    body=json.dumps({
        "inputText": "How does Amazon Bedrock handle RAG?",
        "dimensions": 1024,       # 256, 512, or 1024
        "normalize": True         # L2-normalize for cosine similarity
    })
)
embedding = json.loads(response["body"].read())["embedding"]
# Returns: [0.0234, -0.0891, 0.0456, ...]  (1024 floats)

# Cohere Embed v3 — multilingual, 100+ languages
response = bedrock.invoke_model(
    modelId="cohere.embed-multilingual-v3",
    body=json.dumps({
        "texts": ["How does Bedrock work?", "Comment fonctionne Bedrock?"],
        "input_type": "search_document",  # or "search_query"
        "truncate": "END"
    })
)`;

const codeImageGen = `# Nova Canvas — text-to-image generation
response = bedrock.invoke_model(
    modelId="amazon.nova-canvas-v1:0",
    body=json.dumps({
        "taskType": "TEXT_IMAGE",
        "textToImageParams": {
            "text": "Modern serverless architecture diagram, isometric, clean",
            "negativeText": "blurry, text, watermark"
        },
        "imageGenerationConfig": {
            "width": 1024, "height": 1024,
            "numberOfImages": 1,
            "cfgScale": 8.0,     # prompt adherence (1-20)
            "seed": 42           # reproducibility
        }
    })
)
image_bytes = json.loads(response["body"].read())["images"][0]
# Base64-encoded PNG — decode and save

# Image editing / inpainting
response = bedrock.invoke_model(
    modelId="amazon.nova-canvas-v1:0",
    body=json.dumps({
        "taskType": "INPAINTING",
        "inPaintingParams": {
            "image": base64_image,
            "maskPrompt": "the background",
            "text": "futuristic cloud data center"
        }
    })
)`;

const codeAsyncInvoke = `# Submit batch job — ~50% cheaper than on-demand
response = bedrock.start_async_invoke(
    modelId="us.anthropic.claude-sonnet-4-20250514",
    modelInput={
        "messages": [{"role": "user", "content": [{"text": "Summarize..."}]}],
        "max_tokens": 1024
    },
    outputDataConfig={"s3OutputDataConfig": {"s3Uri": "s3://bucket/output/"}}
)
invocation_arn = response["invocationArn"]

# Poll for completion
import time
while True:
    status = bedrock.get_async_invoke(invocationArn=invocation_arn)
    if status["status"] in ("Completed", "Failed"):
        break
    time.sleep(30)

# Read results from S3
if status["status"] == "Completed":
    output_uri = status["outputDataConfig"]["s3OutputDataConfig"]["s3Uri"]
    # Download and parse the output JSON from S3`;

const codeRetrieve = `response = bedrock_agent.retrieve(
    knowledgeBaseId="KB_ID",
    retrievalQuery={"text": "What is prompt caching in Bedrock?"},
    retrievalConfiguration={
        "vectorSearchConfiguration": {
            "numberOfResults": 5,
            "overrideSearchType": "HYBRID",  # SEMANTIC or HYBRID (BM25+kNN)
            "filter": {
                "andAll": [
                    {"equals": {"key": "category", "value": "bedrock"}},
                    {"greaterThan": {"key": "date", "value": "2024-01-01"}}
                ]
            }
        }
    }
)
for result in response["retrievalResults"]:
    print(f"Score: {result['score']:.3f}")
    print(f"Text: {result['content']['text'][:200]}")
    print(f"Source: {result['location']['s3Location']['uri']}")`;

const codeRetrieveAndGenerate = `# Single-call managed RAG — retrieval + generation + citations
response = bedrock_agent.retrieve_and_generate(
    input={"text": "What chunking strategy should I use for legal docs?"},
    retrieveAndGenerateConfiguration={
        "type": "KNOWLEDGE_BASE",
        "knowledgeBaseConfiguration": {
            "knowledgeBaseId": "KB_ID",
            "modelArn": "arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-sonnet-4-20250514-v1:0",
            "retrievalConfiguration": {
                "vectorSearchConfiguration": {"numberOfResults": 5}
            }
        }
    }
)
print(response["output"]["text"])

# Citations — trace which chunks informed the answer
for citation in response["citations"]:
    for ref in citation["retrievedReferences"]:
        print(f"  Source: {ref['location']['s3Location']['uri']}")
        print(f"  Chunk: {ref['content']['text'][:100]}...")

# Multi-turn RAG with session persistence
response2 = bedrock_agent.retrieve_and_generate(
    input={"text": "What about for medical records specifically?"},
    retrieveAndGenerateConfiguration={...},
    sessionId=response["sessionId"]  # continues the conversation
)`;

const codeRerank = `# Re-score retrieved chunks for better relevance
response = bedrock_agent.rerank(
    rerankingConfiguration={
        "type": "BEDROCK_RERANKING_MODEL",
        "bedrockRerankingConfiguration": {
            "modelConfiguration": {
                "modelArn": "arn:aws:bedrock:us-east-1::foundation-model/cohere.rerank-v3-5:0"
            }
        }
    },
    sources=[
        {"type": "INLINE", "inlineDocumentSource": {
            "type": "TEXT",
            "textDocument": {"text": chunk["text"]}
        }}
        for chunk in retrieved_chunks
    ],
    queries=[{"type": "TEXT", "textQuery": {"text": "What is prompt caching?"}}]
)
# Results sorted by relevance score — pass top-K to generation`;

const codeApplyGuardrail = `# Standalone guardrail — works with ANY text source
response = bedrock.apply_guardrail(
    guardrailIdentifier="my-guardrail-id",
    guardrailVersion="1",
    source="OUTPUT",  # "INPUT" for user prompts, "OUTPUT" for model responses
    content=[{"text": {"text": "The user's email is john@example.com and SSN is 123-45-6789"}}]
)

if response["action"] == "GUARDRAIL_INTERVENED":
    # PII was detected and handled
    for output in response["outputs"]:
        print(output["text"])
        # "The user's email is {EMAIL} and SSN is {SSN}"  (ANONYMIZE mode)
    for assessment in response["assessments"]:
        for pii in assessment.get("sensitiveInformationPolicy", {}).get("piiEntities", []):
            print(f"  Found {pii['type']}: action={pii['action']}")

# Contextual Grounding — check RAG faithfulness
response = bedrock.apply_guardrail(
    guardrailIdentifier="grounding-guardrail",
    guardrailVersion="1",
    source="OUTPUT",
    content=[{
        "text": {"text": model_response, "qualifiers": ["grounding_source"]},
    }, {
        "text": {"text": retrieved_context, "qualifiers": ["query"]}
    }]
)`;

const codeInvokeAgent = `response = bedrock_agent.invoke_agent(
    agentId="AGENT_ID",
    agentAliasId="ALIAS_ID",
    sessionId="session-123",
    inputText="What's the status of order #12345?",
    enableTrace=True
)

# Stream the response
for event in response["completion"]:
    if "chunk" in event:
        print(event["chunk"]["bytes"].decode(), end="")
    if "trace" in event:
        # Inspect agent reasoning steps
        trace = event["trace"]["trace"]
        if "orchestrationTrace" in trace:
            orch = trace["orchestrationTrace"]
            if "rationale" in orch:
                print(f"\\nThinking: {orch['rationale']['text']}")
            if "invocationInput" in orch:
                tool = orch["invocationInput"]
                print(f"\\nCalling tool: {tool.get('actionGroupInvocationInput', {}).get('actionGroupName')}")

# Return of Control — human-in-the-loop
# Agent pauses and returns control when configured
# Your app shows the proposed action to a human
# Human approves → send returnControlResults back to agent`;

const codeInvokeFlow = `# Execute a Bedrock Prompt Flow
response = bedrock_agent.invoke_flow(
    flowIdentifier="FLOW_ID",
    flowAliasIdentifier="ALIAS_ID",
    inputs=[{
        "content": {"document": "Summarize this contract clause..."},
        "nodeName": "FlowInput",
        "nodeOutputName": "document"
    }]
)

for event in response["responseStream"]:
    if "flowOutputEvent" in event:
        output = event["flowOutputEvent"]
        print(f"Node: {output['nodeName']}")
        print(f"Output: {output['content']['document']}")`;

const codeCustomization = `# Fine-tune a model on your domain data
response = bedrock.create_model_customization_job(
    jobName="legal-clause-extractor",
    customModelName="legal-claude",
    roleArn="arn:aws:iam::123456789012:role/BedrockCustomizationRole",
    baseModelIdentifier="anthropic.claude-3-haiku-20240307-v1:0",
    customizationType="FINE_TUNING",  # or "CONTINUED_PRE_TRAINING"
    trainingDataConfig={
        "s3Uri": "s3://training-data/legal-finetune.jsonl"
    },
    outputDataConfig={
        "s3Uri": "s3://model-output/"
    },
    hyperParameters={
        "epochCount": "2",
        "batchSize": "8",
        "learningRate": "0.00001"
    }
)

# After training completes, create provisioned throughput (required)
bedrock.create_provisioned_model_throughput(
    modelUnits=1,
    provisionedModelName="legal-claude-prod",
    modelId="arn:aws:bedrock:...:custom-model/legal-claude"
)`;

const codeSessionMgmt = `# Persistent agent sessions
session = bedrock_agent.create_session(
    agentId="AGENT_ID",
    agentAliasId="ALIAS_ID",
    sessionMetadata={"userId": "user-123", "department": "support"}
)
session_id = session["sessionId"]

# Use session across multiple invocations
bedrock_agent.invoke_agent(
    agentId="AGENT_ID", agentAliasId="ALIAS_ID",
    sessionId=session_id,
    inputText="Hello, I need help with my account"
)
# ... later ...
bedrock_agent.invoke_agent(
    agentId="AGENT_ID", agentAliasId="ALIAS_ID",
    sessionId=session_id,  # same session — agent remembers context
    inputText="Can you check my last 3 orders?"
)

# Clean up
bedrock_agent.end_session(
    agentId="AGENT_ID", agentAliasId="ALIAS_ID",
    sessionId=session_id
)`;
