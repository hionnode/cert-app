					</div>

					<h4 class="caption font-semibold uppercase tracking-wide mt-6 mb-3">Vision / Multimodal</h4>
					<div class="bg-surface-0 border border-surface-3 rounded-card p-4 overflow-x-auto">
						<pre class="text-sm text-ink-secondary font-mono leading-relaxed" set:text={codeConverseVision} />
					</div>

					<h4 class="caption font-semibold uppercase tracking-wide mt-6 mb-3">Guardrails integration</h4>
