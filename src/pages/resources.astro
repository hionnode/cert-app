---
import Layout from "../layouts/Layout.astro";
import ResourceGrid from "../components/resources/ResourceGrid";
import resources from "../data/resources.json";
---

<Layout title="Resources">
	<div class="page-container py-8">
		<h1 class="heading-1 mb-2">Resource Library</h1>
		<p class="body-text mb-8">{resources.length} curated resources — AWS docs, blogs, videos, GitHub repos, and practice exams</p>

		<ResourceGrid client:load resources={resources as any} />
	</div>
</Layout>
