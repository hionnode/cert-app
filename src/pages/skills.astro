---
import Layout from "../layouts/Layout.astro";
import SkillsBrowser from "../components/skills/SkillsBrowser";
import examSkills from "../data/exam-skills.json";

const totalSkills = (examSkills as any[]).length;
---

<Layout title="Exam Skills">
	<div class="page-container py-6">
		<h1 class="heading-1 mb-1">Exam Skills Review</h1>
		<p class="body-text mb-6">
			{totalSkills} skills across 5 domains. Write your understanding, then reveal the reference answer.
		</p>

		{totalSkills > 0 ? (
			<SkillsBrowser client:load skills={examSkills as any} />
		) : (
			<div class="card-padded text-center py-8">
				<p class="body-text">Skills data is being generated...</p>
			</div>
		)}
	</div>
</Layout>
