---
import Layout from "../layouts/Layout.astro";
import DomainProgressRings from "../components/dashboard/DomainProgressRings";
import TodayPlan from "../components/dashboard/TodayPlan";
import StudyStreak from "../components/dashboard/StudyStreak";
import WeekOverview from "../components/dashboard/WeekOverview";
import WeakAreas from "../components/dashboard/WeakAreas";
import days from "../data/days.json";
import scenarios from "../data/scenarios.json";

let allPractice: any[] = [];
try { const d1d2 = await import("../data/practice-d1d2.json"); allPractice = allPractice.concat(d1d2.default ?? d1d2); } catch {}
try { const d3d4d5 = await import("../data/practice-d3d4d5.json"); allPractice = allPractice.concat(d3d4d5.default ?? d3d4d5); } catch {}
---

<Layout title="Dashboard">
	<div class="page-container py-6">
		<h1 class="heading-1 mb-8">Dashboard</h1>

		<!-- Current Step (primary focus) -->
		<section class="mb-8">
			<TodayPlan client:load days={days as any} />
		</section>

		<!-- Weak Areas (only renders when there is data) -->
		<section class="mb-8">
			<WeakAreas client:load scenarios={scenarios as any} questions={allPractice as any} />
		</section>

		<!-- Domain Progress + Streak -->
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-8">
			<div class="lg:col-span-2">
				<h2 class="heading-3 mb-3">Domain Progress</h2>
				<DomainProgressRings client:load days={days as any} />
			</div>
			<div class="lg:col-span-1">
				<h2 class="heading-3 mb-3">Study Streak</h2>
				<StudyStreak client:load />
			</div>
		</div>

		<!-- Plan Overview (collapsed) -->
		<details class="card">
			<summary class="heading-3 cursor-pointer flex items-center justify-between p-5">
				Plan Overview
				<div class="i-lucide-chevron-down w-5 h-5 text-ink-muted" />
			</summary>
			<div class="px-5 pb-5">
				<WeekOverview client:load days={days as any} />
			</div>
		</details>
	</div>
</Layout>
