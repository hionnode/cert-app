---
import Layout from "../layouts/Layout.astro";
import DomainProgressRings from "../components/dashboard/DomainProgressRings";
import TodayPlan from "../components/dashboard/TodayPlan";
import StudyStreak from "../components/dashboard/StudyStreak";
import WeekOverview from "../components/dashboard/WeekOverview";
import days from "../data/days.json";
import { DOMAINS, EXAM_INFO } from "../lib/constants";
---

<Layout title="Dashboard">
	<div class="page-container py-8">
		<div class="flex items-center justify-between mb-8">
			<div>
				<h1 class="heading-1">Dashboard</h1>
				<p class="body-text mt-1">AWS Certified Generative AI Developer - Professional</p>
			</div>
			<div class="hidden sm:flex items-center gap-3">
				<div class="card-padded text-center">
					<div class="text-2xl font-bold text-primary-500">{EXAM_INFO.passingScore}</div>
					<div class="caption">Passing Score</div>
				</div>
				<div class="card-padded text-center">
					<div class="text-2xl font-bold text-secondary-500">{EXAM_INFO.totalQuestions}</div>
					<div class="caption">Questions</div>
				</div>
				<div class="card-padded text-center">
					<div class="text-2xl font-bold text-ink">{EXAM_INFO.duration}m</div>
					<div class="caption">Duration</div>
				</div>
			</div>
		</div>

		<!-- Domain Progress -->
		<section class="mb-8">
			<h2 class="heading-3 mb-4">Domain Progress</h2>
			<DomainProgressRings client:load days={days as any} />
		</section>

		<!-- Streak + Today -->
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
			<div class="lg:col-span-1">
				<StudyStreak client:load />
			</div>
			<div class="lg:col-span-2">
				<TodayPlan client:load days={(days as any)} />
			</div>
		</div>

		<!-- Week Overview -->
		<section>
			<h2 class="heading-3 mb-4">4-Week Plan</h2>
			<WeekOverview client:load days={days as any} />
		</section>
	</div>
</Layout>
