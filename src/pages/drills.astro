---
import Layout from "../layouts/Layout.astro";
import orderingSequences from "../data/ordering-sequences.json";
import matchingExercises from "../data/matching-exercises.json";
---

<Layout title="Drills">
	<div class="page-container py-8">
		<h1 class="heading-1 mb-2">Practice Drills</h1>
		<p class="body-text mb-8">Ordering sequences and matching exercises for exam day</p>

		<!-- Ordering Drills -->
		<section class="mb-12">
			<h2 class="heading-2 mb-6">Ordering Sequences</h2>
			<p class="body-text mb-4">Arrange the steps in the correct order</p>

			<div class="space-y-6">
				{(orderingSequences as any[]).map((seq: any) => (
					<details class="card group">
						<summary class="p-4 cursor-pointer flex items-center justify-between hover:bg-surface-1 rounded-card transition-colors">
							<h3 class="heading-3">{seq.title}</h3>
							<div class="i-lucide-chevron-down w-5 h-5 text-ink-muted group-open:rotate-180 transition-transform" />
						</summary>
						<div class="px-4 pb-4">
							<ol class="space-y-2">
								{seq.steps.map((step: string, i: number) => (
									<li class="flex items-center gap-3 p-3 bg-surface-1 rounded-button">
										<span class="w-7 h-7 bg-primary-500 text-white rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">{i + 1}</span>
										<span class="text-sm">{step}</span>
									</li>
								))}
							</ol>
						</div>
					</details>
				))}
			</div>
		</section>

		<!-- Matching Drills -->
		<section>
			<h2 class="heading-2 mb-6">Matching Exercises</h2>
			<p class="body-text mb-4">Match the left column to the right column</p>

			<div class="space-y-6">
				{(matchingExercises as any[]).map((exercise: any) => (
					<details class="card group">
						<summary class="p-4 cursor-pointer flex items-center justify-between hover:bg-surface-1 rounded-card transition-colors">
							<h3 class="heading-3">{exercise.title}</h3>
							<div class="i-lucide-chevron-down w-5 h-5 text-ink-muted group-open:rotate-180 transition-transform" />
						</summary>
						<div class="px-4 pb-4">
							<div class="overflow-x-auto">
								<table class="w-full text-sm">
									<thead>
										<tr class="border-b border-surface-3">
											<th class="text-left py-2 px-3 font-semibold text-ink-secondary">Trigger / Pattern</th>
											<th class="text-left py-2 px-3 font-semibold text-ink-secondary">AWS Service / Answer</th>
										</tr>
									</thead>
									<tbody>
										{exercise.pairs.map((pair: any) => (
											<tr class="border-b border-surface-2 hover:bg-surface-1">
												<td class="py-2 px-3 font-medium">{pair.left}</td>
												<td class="py-2 px-3 text-primary-600 font-semibold">{pair.right}</td>
											</tr>
										))}
									</tbody>
								</table>
							</div>
						</div>
					</details>
				))}
			</div>
		</section>
	</div>
</Layout>
