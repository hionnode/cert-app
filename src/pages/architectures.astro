---
import Layout from "../layouts/Layout.astro";
import architectures from "../data/architectures.json";
---

<Layout title="Architecture Diagrams">
	<div class="page-container py-8">
		<h1 class="heading-1 mb-2">Architecture Patterns</h1>
		<p class="body-text mb-8">4 reference architectures that combine all exam domains</p>

		<div class="space-y-8">
			{(architectures as any[]).map((arch: any) => (
				<div class="card-padded">
					<h2 class="heading-2 mb-3">{arch.title}</h2>
					<p class="body-text mb-4">{arch.description}</p>

					<!-- Flow steps -->
					<div class="bg-surface-1 rounded-lg p-4 overflow-x-auto">
						<div class="flex items-center flex-wrap gap-2">
							{arch.steps.map((step: any, i: number) => (
								<>
									<div class="flex items-center gap-2 bg-surface-0 border border-surface-3 rounded-button px-3 py-2 text-sm font-mono whitespace-nowrap">
										<span class="font-semibold text-primary-600">{step.service}</span>
										{step.action && <span class="text-ink-muted">({step.action})</span>}
									</div>
									{i < arch.steps.length - 1 && (
										<div class="i-lucide-arrow-right w-4 h-4 text-ink-muted flex-shrink-0" />
									)}
								</>
							))}
						</div>
					</div>

					{arch.monitoring && (
						<div class="mt-4 flex items-start gap-2">
							<div class="i-lucide-activity w-4 h-4 text-secondary-500 mt-0.5 flex-shrink-0" />
							<span class="text-sm text-ink-secondary"><strong>Monitoring:</strong> {arch.monitoring}</span>
						</div>
					)}
					{arch.costNote && (
						<div class="mt-2 flex items-start gap-2">
							<div class="i-lucide-dollar-sign w-4 h-4 text-accent-gold mt-0.5 flex-shrink-0" />
							<span class="text-sm text-ink-secondary"><strong>Cost:</strong> {arch.costNote}</span>
						</div>
					)}
				</div>
			))}
		</div>
	</div>
</Layout>
