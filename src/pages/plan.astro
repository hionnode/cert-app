---
import Layout from "../layouts/Layout.astro";
import { WEEKS } from "../lib/constants";
import days from "../data/days.json";
---

<Layout title="Study Plan">
	<div class="page-container py-8">
		<h1 class="heading-1 mb-2">28-Day Study Plan</h1>
		<p class="body-text mb-8">Organized across 4 weeks covering all 5 exam domains</p>

		{WEEKS.map((week) => (
			<section class="mb-10">
				<div class="flex items-center gap-3 mb-4">
					<div class="w-10 h-10 rounded-full bg-primary-500 text-white flex items-center justify-center font-bold">
						W{week.number}
					</div>
					<div>
						<h2 class="heading-2">Week {week.number}</h2>
						<p class="caption">{week.title}</p>
					</div>
				</div>

				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
					{week.days.map((dayNum) => {
						const day = (days as any[]).find((d: any) => d.number === dayNum);
						if (!day) return null;
						return (
							<a href={`/day/${day.number}`} class="card p-4 hover:border-primary-400 transition-colors group">
								<div class="flex items-center justify-between mb-2">
									<span class={`badge-domain-${day.domain}`}>Domain {day.domain}</span>
									<span class="caption">{day.weekday}</span>
								</div>
								<h3 class="font-semibold text-ink group-hover:text-primary-600 transition-colors mb-1">
									Day {day.number}
								</h3>
								<p class="text-sm text-ink-secondary line-clamp-2">{day.title}</p>
								<div class="mt-3 flex items-center gap-2 text-xs text-ink-muted">
									<span>{day.tasks.length} tasks</span>
									<span>-</span>
									<span>{day.scenarioIds.length} scenarios</span>
								</div>
							</a>
						);
					})}
				</div>
			</section>
		))}
	</div>
</Layout>
