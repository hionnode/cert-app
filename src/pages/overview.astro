---
import Layout from "../layouts/Layout.astro";
import { DOMAINS, EXAM_INFO } from "../lib/constants";

const questionTypes = [
	{ name: "Multiple Choice", desc: "1 correct answer out of 4 options", icon: "i-lucide-circle-dot" },
	{ name: "Multiple Response", desc: "2+ correct answers out of 5+ options. Must select all.", icon: "i-lucide-check-square" },
	{ name: "Ordering", desc: "Arrange 3-5 steps in the correct sequence", icon: "i-lucide-arrow-down-up" },
	{ name: "Matching", desc: "Match 3-7 items from two columns correctly", icon: "i-lucide-link" },
];

const domainTopics: Record<number, string[]> = {
	1: ["Amazon Bedrock", "RAG & Knowledge Bases", "Vector Stores", "Prompt Engineering", "FM Selection", "SageMaker Fine-Tuning", "Data Pipelines"],
	2: ["Bedrock Agents", "AgentCore", "Strands SDK", "MCP", "Step Functions", "API Gateway", "Q Business & Q Developer", "CI/CD for GenAI"],
	3: ["Guardrails", "Automated Reasoning", "IAM & VPC", "PII Detection", "Responsible AI", "AgentCore Policy", "Compliance Frameworks"],
	4: ["Prompt Caching", "Semantic Caching", "Model Cascading", "Cost Tracking", "Provisioned Throughput", "Batch Inference"],
	5: ["Bedrock Evaluations", "LLM-as-a-Judge", "RAG Evaluation", "X-Ray Tracing", "CloudWatch Observability", "Agent Testing"],
};

const keyServices = [
	{ name: "Amazon Bedrock", role: "Foundation model access, Knowledge Bases, Agents, Guardrails, Evaluations", primary: true },
	{ name: "Bedrock AgentCore", role: "Deploy & operate agents at scale — Runtime, Gateway, Policy, Memory, Observability", primary: true },
	{ name: "Amazon SageMaker", role: "Custom model training, LoRA fine-tuning, endpoints, Model Registry", primary: true },
	{ name: "AWS Step Functions", role: "Orchestration — circuit breakers, human-in-the-loop, prompt chaining", primary: false },
	{ name: "Amazon OpenSearch", role: "Vector search, hybrid search (BM25 + k-NN) for RAG", primary: false },
	{ name: "AWS Lambda", role: "Serverless compute for GenAI workflows, MCP servers, data processing", primary: false },
	{ name: "Amazon API Gateway", role: "API management, rate limiting, streaming, AI gateway pattern", primary: false },
	{ name: "Amazon DynamoDB", role: "Conversation history, metadata co-indexing, caching", primary: false },
	{ name: "Amazon CloudWatch", role: "GenAI observability, metrics, Model Invocation Logging", primary: false },
	{ name: "Amazon Q", role: "Q Business (enterprise search) + Q Developer (code assistance)", primary: false },
];
---

<Layout title="Certification Overview">
	<div class="page-container py-8">

		<!-- Hero -->
		<section class="mb-10">
			<div class="flex items-center gap-3 mb-3">
				<div class="w-12 h-12 bg-primary-500 rounded-xl flex items-center justify-center">
					<div class="i-lucide-award w-7 h-7 text-white" />
				</div>
				<div>
					<span class="badge bg-primary-100 text-primary-700 mb-1">Professional Level</span>
					<h1 class="heading-1">{EXAM_INFO.code}: {EXAM_INFO.name}</h1>
				</div>
			</div>
			<p class="body-text max-w-3xl mt-4">
				This certification validates your ability to <strong>integrate Foundation Models (FMs) into applications and business workflows</strong> using AWS technologies. It's designed for developers who build production GenAI solutions — not ML researchers or data scientists.
			</p>
			<p class="body-text max-w-3xl mt-3">
				Think of it as proving you can take a foundation model (like Claude, Nova, or Llama) and build a real, secure, cost-effective application around it using AWS services.
			</p>
		</section>

		<!-- At a Glance Stats -->
		<section class="mb-10">
			<h2 class="heading-2 mb-5">
				<span class="i-lucide-bar-chart-3 w-6 h-6 inline-block mr-2 text-secondary-500" />
				At a Glance
			</h2>
			<div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
				<div class="card-padded text-center">
					<div class="text-4xl font-bold text-secondary-500 font-display">{EXAM_INFO.duration}</div>
					<div class="text-sm text-ink-secondary mt-1">minutes</div>
					<div class="caption mt-2">3 hours to complete</div>
				</div>
				<div class="card-padded text-center">
					<div class="text-4xl font-bold text-secondary-500 font-display">{EXAM_INFO.totalQuestions}</div>
					<div class="text-sm text-ink-secondary mt-1">questions</div>
					<div class="caption mt-2">{EXAM_INFO.scoredQuestions} scored + {EXAM_INFO.totalQuestions - EXAM_INFO.scoredQuestions} unscored</div>
				</div>
				<div class="card-padded text-center">
					<div class="text-4xl font-bold text-primary-500 font-display">{EXAM_INFO.passingScore}</div>
					<div class="text-sm text-ink-secondary mt-1">out of {EXAM_INFO.maxScore}</div>
					<div class="caption mt-2">~75% to pass</div>
				</div>
				<div class="card-padded text-center">
					<div class="text-4xl font-bold text-ink font-display">${EXAM_INFO.cost}</div>
					<div class="text-sm text-ink-secondary mt-1">exam fee</div>
					<div class="caption mt-2">${EXAM_INFO.voucherCost} with voucher</div>
				</div>
			</div>
		</section>

		<!-- 5 Domains -->
		<section class="mb-10">
			<h2 class="heading-2 mb-2">
				<span class="i-lucide-layers w-6 h-6 inline-block mr-2 text-primary-500" />
				5 Exam Domains
			</h2>
			<p class="body-text mb-6">The exam covers 5 domains with different weights. Focus most on Domains 1 & 2 — they make up <strong>57% of the exam</strong>.</p>

			<div class="space-y-4">
				{DOMAINS.map((d) => (
					<div class="card overflow-hidden">
						<div class="flex items-stretch">
							<!-- Weight bar -->
							<div class="w-2 flex-shrink-0" style={`background-color: ${d.color}`} />
							<div class="flex-1 p-5">
								<div class="flex items-center justify-between mb-3">
									<div class="flex items-center gap-3">
										<span class={`badge-domain-${d.id}`}>D{d.id}</span>
										<h3 class="heading-3">{d.name}</h3>
									</div>
									<div class="text-right">
										<span class="text-2xl font-bold font-display" style={`color: ${d.color}`}>{d.weight}%</span>
										<div class="caption">~{d.approxQuestions} questions</div>
									</div>
								</div>

								<!-- Proportional bar -->
								<div class="w-full bg-surface-2 rounded-full h-3 mb-4">
									<div class="h-3 rounded-full transition-all" style={`width: ${d.weight}%; background-color: ${d.color}`} />
								</div>

								<!-- Key topics -->
								<div class="flex flex-wrap gap-2">
									{(domainTopics[d.id] ?? []).map((topic: string) => (
										<span class="badge bg-surface-2 text-ink-secondary">{topic}</span>
									))}
								</div>
							</div>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- Question Types -->
		<section class="mb-10">
			<h2 class="heading-2 mb-2">
				<span class="i-lucide-help-circle w-6 h-6 inline-block mr-2 text-accent-gold" />
				Question Types
			</h2>
			<p class="body-text mb-6">Unlike most AWS exams, AIP-C01 includes <strong>ordering and matching</strong> questions — not just multiple choice.</p>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
				{questionTypes.map((q) => (
					<div class="card-padded">
						<div class={`${q.icon} w-8 h-8 text-secondary-500 mb-3`} />
						<h3 class="heading-3 mb-1">{q.name}</h3>
						<p class="caption">{q.desc}</p>
					</div>
				))}
			</div>

			<div class="card-padded mt-4 bg-accent-gold/5 border-accent-gold/20">
				<div class="flex items-start gap-3">
					<div class="i-lucide-info w-5 h-5 text-accent-gold flex-shrink-0 mt-0.5" />
					<div>
						<p class="text-sm font-semibold text-ink">No penalty for guessing</p>
						<p class="caption">Unanswered questions are scored as incorrect. Always answer every question — never leave blanks.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Key AWS Services -->
		<section class="mb-10">
			<h2 class="heading-2 mb-2">
				<span class="i-lucide-server w-6 h-6 inline-block mr-2 text-primary-500" />
				Key AWS Services Tested
			</h2>
			<p class="body-text mb-6">The exam tests <strong>70+ AWS services</strong>, but these are the core ones you must know deeply:</p>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
				{keyServices.map((svc) => (
					<div class={`flex items-start gap-4 p-4 rounded-card border ${svc.primary ? "bg-primary-50 border-primary-200" : "bg-surface-0 border-surface-3"}`}>
						<div class={`w-2 h-2 rounded-full flex-shrink-0 mt-2 ${svc.primary ? "bg-primary-500" : "bg-ink-muted"}`} />
						<div>
							<h4 class={`text-sm font-semibold ${svc.primary ? "text-primary-700" : "text-ink"}`}>{svc.name}</h4>
							<p class="caption mt-0.5">{svc.role}</p>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- Who Should Take This -->
		<section class="mb-10">
			<h2 class="heading-2 mb-2">
				<span class="i-lucide-user-check w-6 h-6 inline-block mr-2 text-secondary-500" />
				Who Is This For?
			</h2>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
				<div class="card-padded">
					<h3 class="heading-3 text-primary-600 mb-4">
						<span class="i-lucide-check-circle w-5 h-5 inline-block mr-2" />
						You Should Know
					</h3>
					<ul class="space-y-3">
						<li class="flex items-start gap-2 text-sm text-ink-secondary">
							<div class="i-lucide-check w-4 h-4 text-primary-500 flex-shrink-0 mt-0.5" />
							2+ years building production apps on AWS
						</li>
						<li class="flex items-start gap-2 text-sm text-ink-secondary">
							<div class="i-lucide-check w-4 h-4 text-primary-500 flex-shrink-0 mt-0.5" />
							General AI/ML or data engineering experience
						</li>
						<li class="flex items-start gap-2 text-sm text-ink-secondary">
							<div class="i-lucide-check w-4 h-4 text-primary-500 flex-shrink-0 mt-0.5" />
							1 year hands-on with GenAI solutions
						</li>
						<li class="flex items-start gap-2 text-sm text-ink-secondary">
							<div class="i-lucide-check w-4 h-4 text-primary-500 flex-shrink-0 mt-0.5" />
							AWS compute, storage, networking basics
						</li>
						<li class="flex items-start gap-2 text-sm text-ink-secondary">
							<div class="i-lucide-check w-4 h-4 text-primary-500 flex-shrink-0 mt-0.5" />
							Security best practices and IAM
						</li>
					</ul>
				</div>

				<div class="card-padded">
					<h3 class="heading-3 text-ink-muted mb-4">
						<span class="i-lucide-x-circle w-5 h-5 inline-block mr-2" />
						Out of Scope
					</h3>
					<ul class="space-y-3">
						<li class="flex items-start gap-2 text-sm text-ink-muted">
							<div class="i-lucide-x w-4 h-4 text-ink-muted flex-shrink-0 mt-0.5" />
							Model development and training from scratch
						</li>
						<li class="flex items-start gap-2 text-sm text-ink-muted">
							<div class="i-lucide-x w-4 h-4 text-ink-muted flex-shrink-0 mt-0.5" />
							Advanced ML techniques (transformers, attention)
						</li>
						<li class="flex items-start gap-2 text-sm text-ink-muted">
							<div class="i-lucide-x w-4 h-4 text-ink-muted flex-shrink-0 mt-0.5" />
							Data engineering and feature engineering
						</li>
						<li class="flex items-start gap-2 text-sm text-ink-muted">
							<div class="i-lucide-x w-4 h-4 text-ink-muted flex-shrink-0 mt-0.5" />
							Math behind neural networks or embeddings
						</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- What You'll Prove -->
		<section class="mb-10">
			<h2 class="heading-2 mb-6">
				<span class="i-lucide-target w-6 h-6 inline-block mr-2 text-accent-coral" />
				What You'll Prove You Can Do
			</h2>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
				{[
					{ icon: "i-lucide-database", text: "Design RAG systems with vector stores and Knowledge Bases" },
					{ icon: "i-lucide-bot", text: "Build agentic AI with tools, memory, and orchestration" },
					{ icon: "i-lucide-wand-2", text: "Apply prompt engineering and management at scale" },
					{ icon: "i-lucide-shield", text: "Implement guardrails, PII protection, and compliance" },
					{ icon: "i-lucide-dollar-sign", text: "Optimize GenAI costs with caching, routing, and batching" },
					{ icon: "i-lucide-test-tubes", text: "Evaluate and troubleshoot FM applications in production" },
				].map((item) => (
					<div class="flex items-start gap-3 p-4 bg-surface-0 rounded-card border border-surface-3">
						<div class={`${item.icon} w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5`} />
						<span class="text-sm text-ink-secondary">{item.text}</span>
					</div>
				))}
			</div>
		</section>

		<!-- CTA -->
		<section class="text-center py-10 bg-primary-50 rounded-card border border-primary-200">
			<div class="i-lucide-rocket w-10 h-10 text-primary-500 mx-auto mb-4" />
			<h2 class="heading-2 mb-2">Ready to Start?</h2>
			<p class="body-text mb-6 max-w-lg mx-auto">The 28-day study plan covers every domain with hands-on labs, scenarios, comparison tables, and practice drills.</p>
			<div class="flex items-center justify-center gap-4">
				<a href="/plan" class="btn-primary text-lg px-6 py-3">
					<span class="i-lucide-calendar w-5 h-5" />
					Start 28-Day Plan
				</a>
				<a href="/" class="btn-ghost text-lg px-6 py-3">
					<span class="i-lucide-layout-dashboard w-5 h-5" />
					Dashboard
				</a>
			</div>
		</section>

	</div>
</Layout>
