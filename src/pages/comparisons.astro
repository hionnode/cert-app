---
import Layout from "../layouts/Layout.astro";
import ComparisonTable from "../components/comparisons/ComparisonTable";
import tables from "../data/comparisons.json";
import { DOMAINS } from "../lib/constants";
---

<Layout title="Comparison Tables">
	<div class="page-container py-8">
		<h1 class="heading-1 mb-2">Service Comparison Tables</h1>
		<p class="body-text mb-8">{tables.length} tables covering the key "when X vs Y" exam decisions</p>

		<div class="space-y-10">
			{(tables as any[]).map((table: any) => {
				const domain = DOMAINS.find((d) => d.id === table.domain);
				return (
					<section>
						<div class="flex items-center gap-3 mb-4">
							<span class={`badge-domain-${table.domain}`}>{domain?.shortName}</span>
							<h2 class="heading-2">{table.title}</h2>
						</div>
						{table.description && <p class="body-text mb-4">{table.description}</p>}
						<ComparisonTable client:visible table={table} />
					</section>
				);
			})}
		</div>
	</div>
</Layout>
