---
import { NAV_ITEMS, SECONDARY_NAV } from "../lib/constants";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Interactive 28-step study plan for the AWS Certified Generative AI Developer - Professional (AIP-C01) exam" } = Astro.props;
const allNav = [...NAV_ITEMS, ...SECONDARY_NAV];
---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<title>{title} | AIP-C01 Study Hub</title>
		<script is:inline>
			(function() {
				var t = localStorage.getItem('theme');
				if (t === 'light') {
					document.documentElement.classList.remove('dark');
				} else {
					document.documentElement.classList.add('dark');
					if (!t) localStorage.setItem('theme', 'dark');
				}
			})();
		</script>
	</head>
	<body class="bg-surface-0 text-ink font-mono min-h-screen">
		<!-- Mobile header -->
		<header class="lg:hidden sticky top-0 z-50 bg-surface-0 border-b border-surface-3 px-4 py-3 flex items-center justify-between">
			<a href="/" class="flex items-center gap-2">
				<span class="text-accent-aqua font-bold text-base">AIP-C01</span>
				<span class="text-[13px] text-ink-muted">Study Hub</span>
			</a>
			<button id="theme-toggle-mobile" class="p-1.5 hover:bg-surface-2 rounded-sm transition-colors" aria-label="Toggle theme">
				<div class="i-lucide-sun w-4 h-4 text-accent-yellow hidden dark:block" />
				<div class="i-lucide-moon w-4 h-4 text-accent-blue dark:hidden" />
			</button>
		</header>

		<div class="flex min-h-screen">
			<!-- Desktop sidebar -->
			<aside id="sidebar" class="hidden lg:flex flex-col bg-surface-0 border-r border-surface-3 sticky top-0 h-screen overflow-y-auto overflow-x-hidden transition-[width] duration-200 ease-out w-14" data-collapsed="true">
				<!-- Logo -->
				<div class="p-3 border-b border-surface-3 flex items-center justify-center">
					<a href="/" class="block text-center">
						<span class="text-accent-aqua font-bold text-base sidebar-expanded-only hidden">AIP-C01</span>
						<span class="text-[13px] text-ink-muted sidebar-expanded-only hidden block">Study Hub</span>
						<span class="text-accent-aqua font-bold text-base sidebar-collapsed-only">AIP</span>
					</a>
				</div>

				<!-- Nav -->
				<nav class="flex-1 py-3">
					{NAV_ITEMS.map((item) => (
						<a href={item.href} class="sidebar-nav-link flex items-center gap-2.5 px-4 py-2.5 text-ink-muted hover:text-ink hover:bg-surface-2 transition-colors whitespace-nowrap overflow-hidden" title={item.label}>
							<div class={`${item.icon} w-5 h-5 shrink-0`} />
							<span class="sidebar-label">{item.label}</span>
						</a>
					))}

					<div class="mt-3"></div>

					{SECONDARY_NAV.map((item) => (
						<a href={item.href} class="sidebar-nav-link flex items-center gap-2.5 px-4 py-2.5 text-ink-muted hover:text-ink hover:bg-surface-2 transition-colors whitespace-nowrap overflow-hidden" title={item.label}>
							<div class={`${item.icon} w-5 h-5 shrink-0`} />
							<span class="sidebar-label">{item.label}</span>
						</a>
					))}
				</nav>

				<!-- Footer -->
				<div class="py-3 border-t border-surface-3 flex flex-col items-center gap-2">
					<button id="sidebar-toggle" class="p-2 text-ink-muted hover:text-ink hover:bg-surface-2 rounded-sm transition-colors cursor-pointer" aria-label="Toggle sidebar">
						<div class="i-lucide-panel-left-open w-5 h-5 sidebar-collapsed-only" />
						<div class="i-lucide-panel-left-close w-5 h-5 sidebar-expanded-only hidden" />
					</button>
					<button id="theme-toggle-desktop" class="p-2 hover:bg-surface-2 rounded-sm transition-colors" aria-label="Toggle theme">
						<div class="i-lucide-sun w-4 h-4 text-accent-yellow hidden dark:block" />
						<div class="i-lucide-moon w-4 h-4 text-accent-blue dark:hidden" />
					</button>
				</div>
			</aside>

			<!-- Main content -->
			<main class="flex-1 pb-20 lg:pb-8">
				<slot />
			</main>
		</div>

		<!-- Mobile bottom nav -->
		<nav class="lg:hidden fixed bottom-0 left-0 right-0 bg-surface-0 border-t border-surface-3 flex justify-around py-2 z-50">
			<a href="/" class="flex flex-col items-center gap-1 px-2 py-2 text-ink-muted hover:text-accent-aqua">
				<div class="i-lucide-layout-dashboard w-5 h-5" />
				<span class="text-[13px] font-semibold">Home</span>
			</a>
			<a href="/plan" class="flex flex-col items-center gap-1 px-2 py-2 text-ink-muted hover:text-accent-aqua">
				<div class="i-lucide-calendar w-5 h-5" />
				<span class="text-[13px] font-semibold">Plan</span>
			</a>
			<a href="/practice" class="flex flex-col items-center gap-1 px-2 py-2 text-ink-muted hover:text-accent-aqua">
				<div class="i-lucide-brain w-5 h-5" />
				<span class="text-[13px] font-semibold">Practice</span>
			</a>
			<a href="/reference" class="flex flex-col items-center gap-1 px-2 py-2 text-ink-muted hover:text-accent-aqua">
				<div class="i-lucide-table-2 w-5 h-5" />
				<span class="text-[13px] font-semibold">Reference</span>
			</a>
			<a href="/scenarios" class="flex flex-col items-center gap-1 px-2 py-2 text-ink-muted hover:text-accent-aqua">
				<div class="i-lucide-lightbulb w-5 h-5" />
				<span class="text-[13px] font-semibold">Scenarios</span>
			</a>
		</nav>

		<script is:inline>
			// Theme toggle
			document.querySelectorAll('[id^="theme-toggle"]').forEach(function(btn) {
				btn.addEventListener('click', function() {
					var isDark = document.documentElement.classList.toggle('dark');
					localStorage.setItem('theme', isDark ? 'dark' : 'light');
				});
			});

			// Sidebar collapse toggle
			(function() {
				var sidebar = document.getElementById('sidebar');
				var toggle = document.getElementById('sidebar-toggle');
				if (!sidebar || !toggle) return;

				var collapsed = localStorage.getItem('sidebar-collapsed') !== 'false';
				applySidebarState(collapsed);

				toggle.addEventListener('click', function() {
					collapsed = !collapsed;
					localStorage.setItem('sidebar-collapsed', String(collapsed));
					applySidebarState(collapsed);
				});

				function applySidebarState(isCollapsed) {
					sidebar.setAttribute('data-collapsed', String(isCollapsed));
					if (isCollapsed) {
						sidebar.classList.remove('w-56');
						sidebar.classList.add('w-14');
					} else {
						sidebar.classList.remove('w-14');
						sidebar.classList.add('w-56');
					}
					// Toggle visibility of labels and icons
					sidebar.querySelectorAll('.sidebar-label').forEach(function(el) {
						el.style.opacity = isCollapsed ? '0' : '1';
						el.style.width = isCollapsed ? '0' : 'auto';
					});
					sidebar.querySelectorAll('.sidebar-expanded-only').forEach(function(el) {
						el.style.display = isCollapsed ? 'none' : '';
					});
					sidebar.querySelectorAll('.sidebar-collapsed-only').forEach(function(el) {
						el.style.display = isCollapsed ? '' : 'none';
					});
				}
			})();
		</script>
	</body>
</html>
