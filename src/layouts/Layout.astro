---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Interactive 28-day study plan for the AWS Certified Generative AI Developer - Professional (AIP-C01) exam" } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&family=Noto+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
		<title>{title} | AIP-C01 Study Hub</title>
	</head>
	<body class="bg-surface-1 text-ink font-sans min-h-screen">
		<!-- Mobile header -->
		<header class="lg:hidden sticky top-0 z-50 bg-surface-0 border-b border-surface-3 px-4 py-3 flex items-center justify-between">
			<a href="/" class="flex items-center gap-2">
				<div class="w-8 h-8 bg-primary-500 rounded-lg flex items-center justify-center text-white font-bold text-sm">AI</div>
				<span class="font-display font-bold text-lg">AIP-C01</span>
			</a>
			<nav class="flex items-center gap-1">
				<a href="/scenarios" class="p-2 rounded-button hover:bg-surface-2" title="Scenarios">
					<div class="i-lucide-lightbulb w-5 h-5 text-ink-secondary" />
				</a>
				<a href="/rules" class="p-2 rounded-button hover:bg-surface-2" title="Rules">
					<div class="i-lucide-list-checks w-5 h-5 text-ink-secondary" />
				</a>
			</nav>
		</header>

		<div class="flex min-h-screen">
			<!-- Desktop sidebar -->
			<aside class="hidden lg:flex flex-col w-64 bg-surface-0 border-r border-surface-3 sticky top-0 h-screen overflow-y-auto">
				<div class="p-5">
					<a href="/" class="flex items-center gap-3">
						<div class="w-10 h-10 bg-primary-500 rounded-xl flex items-center justify-center text-white font-bold">AI</div>
						<div>
							<div class="font-display font-bold text-lg leading-tight">AIP-C01</div>
							<div class="text-xs text-ink-muted">Study Hub</div>
						</div>
					</a>
				</div>

				<nav class="flex-1 px-3 space-y-1">
					<div class="caption px-3 py-2 uppercase tracking-wider">Study</div>
					<a href="/" class="nav-link"><div class="i-lucide-layout-dashboard w-5 h-5" /> Dashboard</a>
					<a href="/plan" class="nav-link"><div class="i-lucide-calendar w-5 h-5" /> Study Plan</a>
					<a href="/scenarios" class="nav-link"><div class="i-lucide-lightbulb w-5 h-5" /> Scenarios</a>
					<a href="/comparisons" class="nav-link"><div class="i-lucide-table-2 w-5 h-5" /> Tables</a>
					<a href="/resources" class="nav-link"><div class="i-lucide-library w-5 h-5" /> Resources</a>

					<div class="caption px-3 py-2 mt-4 uppercase tracking-wider">Practice</div>
					<a href="/rules" class="nav-link"><div class="i-lucide-list-checks w-5 h-5" /> Rules</a>
					<a href="/architectures" class="nav-link"><div class="i-lucide-git-branch w-5 h-5" /> Architectures</a>
					<a href="/drills" class="nav-link"><div class="i-lucide-dumbbell w-5 h-5" /> Drills</a>
					<a href="/exams" class="nav-link"><div class="i-lucide-trophy w-5 h-5" /> Exams</a>
					<a href="/services" class="nav-link"><div class="i-lucide-server w-5 h-5" /> Services</a>
				</nav>

				<div class="p-4 border-t border-surface-3">
					<div class="text-xs text-ink-muted">AWS GenAI Developer Pro</div>
					<div class="text-xs text-ink-muted">28-Day Study Plan</div>
				</div>
			</aside>

			<!-- Main content -->
			<main class="flex-1 pb-20 lg:pb-8">
				<slot />
			</main>
		</div>

		<!-- Mobile bottom nav -->
		<nav class="lg:hidden fixed bottom-0 left-0 right-0 bg-surface-0 border-t border-surface-3 flex justify-around py-2 z-50">
			<a href="/" class="flex flex-col items-center gap-1 px-3 py-1 text-ink-muted hover:text-primary-500">
				<div class="i-lucide-layout-dashboard w-5 h-5" />
				<span class="text-[10px] font-semibold">Home</span>
			</a>
			<a href="/plan" class="flex flex-col items-center gap-1 px-3 py-1 text-ink-muted hover:text-primary-500">
				<div class="i-lucide-calendar w-5 h-5" />
				<span class="text-[10px] font-semibold">Plan</span>
			</a>
			<a href="/scenarios" class="flex flex-col items-center gap-1 px-3 py-1 text-ink-muted hover:text-primary-500">
				<div class="i-lucide-lightbulb w-5 h-5" />
				<span class="text-[10px] font-semibold">Scenarios</span>
			</a>
			<a href="/comparisons" class="flex flex-col items-center gap-1 px-3 py-1 text-ink-muted hover:text-primary-500">
				<div class="i-lucide-table-2 w-5 h-5" />
				<span class="text-[10px] font-semibold">Tables</span>
			</a>
			<a href="/drills" class="flex flex-col items-center gap-1 px-3 py-1 text-ink-muted hover:text-primary-500">
				<div class="i-lucide-dumbbell w-5 h-5" />
				<span class="text-[10px] font-semibold">Drills</span>
			</a>
		</nav>
	</body>
</html>
