---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Interactive 28-day study plan for the AWS Certified Generative AI Developer - Professional (AIP-C01) exam" } = Astro.props;
---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<!-- 0xProto Nerd Font Mono - must be installed locally -->
		<title>{title} | AIP-C01 Study Hub</title>
		<script is:inline>
			(function() {
				const t = localStorage.getItem('theme');
				if (t === 'light') {
					document.documentElement.classList.remove('dark');
				} else {
					document.documentElement.classList.add('dark');
					if (!t) localStorage.setItem('theme', 'dark');
				}
			})();
		</script>
	</head>
	<body class="bg-surface-0 text-ink font-mono min-h-screen">
		<!-- Mobile header -->
		<header class="lg:hidden sticky top-0 z-50 bg-surface-0 border-b border-surface-3 px-4 py-3 flex items-center justify-between">
			<a href="/" class="flex items-center gap-2">
				<span class="text-accent-aqua font-bold text-base">AIP-C01</span>
				<span class="text-[13px] text-ink-muted">Study Hub</span>
			</a>
			<button id="theme-toggle-mobile" class="p-1.5 hover:bg-surface-2 rounded-sm transition-colors" aria-label="Toggle theme">
				<div class="i-lucide-sun w-4 h-4 text-accent-yellow hidden dark:block" />
				<div class="i-lucide-moon w-4 h-4 text-accent-blue dark:hidden" />
			</button>
		</header>

		<div class="flex min-h-screen">
			<!-- Desktop sidebar -->
			<aside class="hidden lg:flex flex-col w-56 bg-surface-0 border-r border-surface-3 sticky top-0 h-screen overflow-y-auto">
				<div class="p-5 border-b border-surface-3">
					<a href="/" class="block">
						<span class="text-accent-aqua font-bold text-base">AIP-C01</span>
						<span class="text-[13px] text-ink-muted block">Study Hub</span>
					</a>
				</div>

				<nav class="flex-1 py-2">
					<a href="/" class="nav-link">Dashboard</a>
					<a href="/plan" class="nav-link">Plan</a>
					<a href="/scenarios" class="nav-link">Scenarios</a>
					<a href="/skills" class="nav-link">Skills</a>

					<div class="mt-4"></div>
					<a href="/practice" class="nav-link">Practice</a>
					<a href="/reference" class="nav-link">Reference</a>
					<a href="/resources" class="nav-link">Resources</a>
				</nav>

				<div class="p-5 border-t border-surface-3 flex items-center justify-between">
					<span class="text-[13px] text-ink-muted">28-day plan</span>
					<button id="theme-toggle-desktop" class="p-1.5 hover:bg-surface-2 rounded-sm transition-colors" aria-label="Toggle theme">
						<div class="i-lucide-sun w-4 h-4 text-accent-yellow hidden dark:block" />
						<div class="i-lucide-moon w-4 h-4 text-accent-blue dark:hidden" />
					</button>
				</div>
			</aside>

			<!-- Main content -->
			<main class="flex-1 pb-20 lg:pb-8">
				<slot />
			</main>
		</div>

		<!-- Mobile bottom nav -->
		<nav class="lg:hidden fixed bottom-0 left-0 right-0 bg-surface-0 border-t border-surface-3 flex justify-around py-2 z-50">
			<a href="/" class="flex flex-col items-center gap-1 px-3 py-1 text-ink-muted hover:text-accent-aqua">
				<div class="i-lucide-layout-dashboard w-5 h-5" />
				<span class="text-[13px] font-semibold">Home</span>
			</a>
			<a href="/plan" class="flex flex-col items-center gap-1 px-3 py-1 text-ink-muted hover:text-accent-aqua">
				<div class="i-lucide-calendar w-5 h-5" />
				<span class="text-[13px] font-semibold">Plan</span>
			</a>
			<a href="/practice" class="flex flex-col items-center gap-1 px-3 py-1 text-ink-muted hover:text-accent-aqua">
				<div class="i-lucide-brain w-5 h-5" />
				<span class="text-[13px] font-semibold">Practice</span>
			</a>
			<a href="/reference" class="flex flex-col items-center gap-1 px-3 py-1 text-ink-muted hover:text-accent-aqua">
				<div class="i-lucide-table-2 w-5 h-5" />
				<span class="text-[13px] font-semibold">Reference</span>
			</a>
			<a href="/scenarios" class="flex flex-col items-center gap-1 px-3 py-1 text-ink-muted hover:text-accent-aqua">
				<div class="i-lucide-lightbulb w-5 h-5" />
				<span class="text-[13px] font-semibold">Scenarios</span>
			</a>
		</nav>

		<script is:inline>
			document.querySelectorAll('[id^="theme-toggle"]').forEach(function(btn) {
				btn.addEventListener('click', function() {
					var isDark = document.documentElement.classList.toggle('dark');
					localStorage.setItem('theme', isDark ? 'dark' : 'light');
				});
			});
		</script>
	</body>
</html>
